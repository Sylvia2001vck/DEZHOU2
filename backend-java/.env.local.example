# 本地/云上密钥与中间件 — 复制为 .env.local 后填写，切勿提交 .env.local
#
#   cp .env.local.example .env.local
#   nano .env.local
#
# 启动前加载（Bash / 云上 Ubuntu）：
#   cd backend-java && source .env.local && java -jar target/nebula-gateway.jar
# 或使用同目录下的：  ./run-gateway.sh

# 与 C++ 进程必须一致（不配则两边都用代码里的 dev 默认值）
export NEBULA_BRIDGE_SECRET='请改成你自己的长随机串'

# 可选：Lettuce / 异步匹配管线
export REDIS_HOST=127.0.0.1
export REDIS_PORT=6379

# 可选：JDBC 用户与 match_message；不配则内存用户 + 同步匹配
export MYSQL_HOST=
export MYSQL_USER=root
export MYSQL_PASSWORD=''
export MYSQL_DATABASE=nebula_poker

# 常用（也可在 shell 里单独 export，不必写进本文件）
# export PORT=8080
# export NEBULA_ROOM_WORKER_HOST=127.0.0.1
# export NEBULA_ROOM_WORKER_PORT=3101
# export NEBULA_REPO_ROOT=/path/to/DEZHOU2
