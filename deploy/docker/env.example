# 复制为 deploy/docker/.env 后填写（勿提交 .env）
#   cp deploy/docker/env.example deploy/docker/.env

# Compose 默认只起 Java 网关（见 docker-compose.yaml 内 NEBULA_ROOM_WORKER_DISABLED）。
# 若自行起 C++ worker 并要连桥，勿设 DISABLED，并配置 NEBULA_ROOM_WORKER_HOST / PORT。

# === 宿主映射：宿主机端口 → 网关容器内 8080 ===
GATEWAY_PUBLISH_PORT=8080

# === 网关密钥（可选 C++ 桥 / 内部接口）===
NEBULA_BRIDGE_SECRET=请改成长随机串与生产一致

# === Redis + MySQL（网关使用）===
# 腾讯云填内网地址；MySQL 在宿主机时用 host.docker.internal
REDIS_HOST=10.0.x.x
REDIS_PORT=6379
MYSQL_HOST=10.0.x.x
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=nebula_poker
MYSQL_PORT=3306

# （可选）腾讯云 CLS / 本地日志已够用
# CLS 投递在控制台配 LogListener 等采集 Docker json 日志，一般不在网关进程里填 API 密钥；见 Tencent 文档。

# === WebSocket：代理 / CLB 空闲切断与心跳（参见 proto-socket HEARTBEAT_INTERVAL_MS、GatewayMain、RoomControlWsService）===
# 浏览器约每 20s 发 ping；以下与 docker-compose 中 ${VAR:-默认值} 一致，可按云上实际改 .env。
NEBULA_JETTY_WS_IDLE_MS=900000
NEBULA_WS_IDLE_DISCONNECT_MS=180000
NEBULA_WS_JETTY_PING_INTERVAL_SEC=20
