# 复制为 deploy/docker/.env 后填写（勿提交 .env）
#   cp deploy/docker/env.example deploy/docker/.env

# Compose 默认只起 Java 网关（见 docker-compose.yaml 内 NEBULA_ROOM_WORKER_DISABLED）。
# 若自行起 C++ worker 并要连桥，勿设 DISABLED，并配置 NEBULA_ROOM_WORKER_HOST / PORT。

# === 宿主映射：宿主机端口 → 网关容器内 8080 ===
GATEWAY_PUBLISH_PORT=8080

# === 网关密钥（可选 C++ 桥 / 内部接口）===
NEBULA_BRIDGE_SECRET=请改成长随机串与生产一致

# === Redis + MySQL（网关使用）===
# 腾讯云填内网地址；MySQL 在宿主机时用 host.docker.internal
REDIS_HOST=10.0.x.x
REDIS_PORT=6379
MYSQL_HOST=10.0.x.x
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=nebula_poker
MYSQL_PORT=3306
# （可选）腾讯云 CLS / 本地日志已够用
