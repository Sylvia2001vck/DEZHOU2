# 复制为 deploy/docker/.env 后填写（勿提交 .env）
#   cp deploy/docker/env.example deploy/docker/.env

# === 宿主映射：compose 里 gateway 暴露端口 ===
GATEWAY_PUBLISH_PORT=8080

# === Java ↔ C++ 桥密钥（必须与 C++ 一致）===
NEBULA_BRIDGE_SECRET=请改成长随机串与生产一致

# 不要在本文件或 shell 里设置 NEBULA_ROOM_WORKER_HOST（网关已由 compose 指向容器名 nebula-room-worker）。

# === 异步匹配（Redis + MySQL 都填才开 MatchWorker）===
# 腾讯云 Redis/MySQL 填 **内网地址**；MySQL 在「宿主机」时用 host.docker.internal
REDIS_HOST=10.0.x.x
REDIS_PORT=6379
MYSQL_HOST=10.0.x.x
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=nebula_poker
MYSQL_PORT=3306

# === C++ 访问 MySQL / Redis（排行榜等，与 Java 可同实例）===
# 若在 Docker 外无独立 MySQL，可与 Java 相同
# MYSQL_* 已由上项覆盖；C++ 也读同名环境变量

# === Redis（C++ 排行榜）===
# 可与上面 REDIS_HOST 相同

# （可选）腾讯云 CLS / 本地日志已够用
